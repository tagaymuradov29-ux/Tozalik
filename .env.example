# --- Majburiy ---
BOT_TOKEN=123456789:AAA...your-token-here
ADMIN_IDS=123456789
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Ixtiyoriy (standart qiymatlar bor) ---
