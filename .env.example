ANNOUNCE_HOUR=9         # yangi sikl vazifalari e'lon qilinadigan soat
REMIND_HOUR=21         # kechki eslatma soati
DEADLINE_HOUR=5        # jarima tekshiriladigan soat
FINE_AMOUNT=100000     # tozalik vazifasi jarimasi
DOOR_FINE_FULL=100000
DOOR_FINE_PARTIAL=80000
COOK_FINE_FULL=100000
COOK_FINE_PARTIAL=80000
